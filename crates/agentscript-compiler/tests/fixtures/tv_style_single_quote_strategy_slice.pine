//@version=5
// Vertical slice: TV-style single-quoted strings + multi-arg `input.*` (title/group/options).
strategy(title='Acrypto - Weighted Strategy v1.4.9', overlay=true, precision=2, commission_value=0.075, commission_type=strategy.commission.percent, initial_capital=1000, currency=currency.USD, default_qty_type=strategy.percent_of_equity, default_qty_value=100, slippage=1)

allow_longs = input.bool(true, 'Allow Longs', group='Trading type')
movestoploss = input.string('TP-2', 'Move stop loss', options=['None', 'Percentage', 'TP-1', 'TP-2', 'TP-3'], group='Stop loss')
from_day = input.int(1, 'From Day', minval=1, maxval=31, group='DataStamp')

group_label = 'Trading type'
escaped = 'it\'s ok'
